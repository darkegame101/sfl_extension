{
  "manifest_version": 3,
  "name": "SFL Auto-Deliver",
  "version": "1.0",
  "description": "Automates Sunflower Land NFT deliveries",
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://sunflower-land.com/*", "https://api.sunflower-land.com/link/callback*"],
      "js": ["islands_graph_data.js", "content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://sunflower-land.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["bridge.js"],
    "matches": ["https://sunflower-land.com/*"]
  }]
}
